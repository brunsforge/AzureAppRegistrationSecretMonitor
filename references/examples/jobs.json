{
  "_comment": [
    "AARM Azure Function — central job configuration file.",
    "Deploy to: Storage Account → Container 'aarm-config' → Blob 'jobs.json'",
    "",
    "CREDENTIAL SETUP (per job that uses client-secret or certificate authMode):",
    "  credentialRef is the Key Vault secret name. Convention: 'aarm-{jobId}'",
    "  The function reads the secret directly from KV at scan time using its UAMI.",
    "",
    "  Option A — Via MAUI Cloud Mode (recommended):",
    "    Use the Add Tenant form in MAUI. The UI sends the credential value to the",
    "    function API which stores it in Key Vault automatically.",
    "",
    "  Option B — Via Azure CLI:",
    "    az keyvault secret set --vault-name <vault> --name aarm-contoso-prod --value <secret>",
    "    Then set credentialRef: 'aarm-contoso-prod' in this file.",
    "",
    "  Local dev fallback (no AARM_KEYVAULT_URI set):",
    "    The function reads from env var AARM_SECRET_<NAME_UPPER_SNAKE>.",
    "    Example: credentialRef 'aarm-contoso-prod' → env var 'AARM_SECRET_AARM_CONTOSO_PROD'"
  ],
  "version": "1.0",
  "jobs": [
    {
      "_comment": "Contoso PROD — daily scan at 06:00 UTC. Custom critical template.",

      "id": "contoso-prod",
      "enabled": true,

      "tenantId": "<contoso-tenant-id>",
      "tenantDisplayName": "Contoso Corporation",

      "authMode": "client-secret",
      "clientId": "<app-registration-client-id-in-contoso-tenant>",
      "credentialRef": "aarm-contoso-prod",

      "schedule": {
        "intervalDays": 1,
        "runAtUtc": "06:00"
      },

      "teamsWebhooks": {
        "status":  "<teams-incoming-webhook-url-for-daily-summary>",
        "alerts":  "<teams-incoming-webhook-url-for-expiring-and-critical-alerts>",
        "errors":  "<teams-incoming-webhook-url-for-scan-errors>"
      },

      "notificationTemplates": {
        "expiring":  null,
        "critical":  "critical-contoso.json",
        "summary":   null,
        "error":     null
      },

      "notificationThresholds": {
        "expiringWithinDays": 30,
        "criticalWithinDays": 7
      },

      "logAnalytics": {
        "workspaceId": "<log-analytics-workspace-id>",
        "enabled": true
      }
    },
    {
      "_comment": "Fabrikam DEV — weekly scan at 08:00 UTC. Custom summary template. Error-only webhooks.",

      "id": "fabrikam-dev",
      "enabled": true,

      "tenantId": "<fabrikam-tenant-id>",
      "tenantDisplayName": "Fabrikam Inc.",
      "environmentName": "DEV",

      "authMode": "client-secret",
      "clientId": "<app-registration-client-id-in-fabrikam-tenant>",
      "credentialRef": "aarm-fabrikam-dev",

      "schedule": {
        "intervalDays": 7,
        "runAtUtc": "08:00"
      },

      "teamsWebhooks": {
        "status":  null,
        "alerts":  null,
        "errors":  "<teams-incoming-webhook-url-for-scan-errors>"
      },

      "notificationTemplates": {
        "expiring":  null,
        "critical":  null,
        "summary":   "summary-fabrikam.json",
        "error":     null
      },

      "notificationThresholds": {
        "expiringWithinDays": 14,
        "criticalWithinDays": 3
      },

      "logAnalytics": {
        "workspaceId": null,
        "enabled": false
      }
    }
  ]
}
