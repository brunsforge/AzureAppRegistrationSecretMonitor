@page "/history"
@page "/history/{TenantName}"
@inject HistoryRepository HistoryRepo
@inject TenantConfigRepository TenantRepo
@inject IDataProvider DataProvider
@inject SettingsService SettingsSvc
@inject AppStateService AppState
@implements IDisposable

<PageTitle>History — AARM</PageTitle>

<div class="aarm-page-header">
    <h1>Scan History</h1>

    <select class="form-select" style="max-width:220px"
            value="@_selectedTenant" @onchange="OnTenantChanged">
        <option value="">— Select tenant —</option>
        @foreach (var t in _tenants)
        {
            <option value="@t.DisplayName">@t.DisplayName</option>
        }
    </select>

    <button class="btn btn-outline-primary btn-sm"
            @onclick="LoadAsync"
            disabled="@string.IsNullOrEmpty(_selectedTenant)">
        Refresh
    </button>
</div>

@if (_loading)
{
    <div class="aarm-loading">Loading history…</div>
}
else if (_error is not null)
{
    <div class="aarm-error">@_error</div>
}
else if (_history is null || _history.Count == 0)
{
    <div class="aarm-empty">
        <p>No scan history yet for this tenant.</p>
        @if (SettingsSvc.Settings.AppMode != "cloud")
        {
            <p>Run a scan from the <a href="/dashboard">Dashboard</a> to start building history.</p>
        }
    </div>
}
else
{
    <table class="aarm-table">
        <thead>
            <tr>
                <th>Scanned</th>
                <th>Apps</th>
                <th>Secrets</th>
                <th>Expired</th>
                <th>Expiring ≤30d</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var entry in _history)
            {
                var hasExpired  = entry.ExpiredCount  > 0;
                var hasExpiring = entry.ExpiringCount > 0;
                <tr>
                    <td>
                        @if (DateTimeOffset.TryParse(entry.ScannedAt, out var dt))
                        {
                            @dt.LocalDateTime.ToString("yyyy-MM-dd  HH:mm")
                        }
                        else { @entry.ScannedAt }
                    </td>
                    <td>@entry.AppCount</td>
                    <td>@entry.SecretCount</td>
                    <td class="@(hasExpired ? "risk-critical" : "")">@entry.ExpiredCount</td>
                    <td class="@(hasExpiring ? "risk-high" : "")">@entry.ExpiringCount</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    [Parameter] public string? TenantName { get; set; }

    private IReadOnlyList<TenantProfile> _tenants = Array.Empty<TenantProfile>();
    private string _selectedTenant = "";
    private bool _loading;
    private string? _error;
    private List<ScanHistoryEntry>? _history;

    protected override async Task OnInitializedAsync()
    {
        _tenants = SettingsSvc.Settings.AppMode == "cloud"
            ? await DataProvider.GetTenantsAsync()
            : await TenantRepo.ListTenantsAsync();

        _selectedTenant =
            (!string.IsNullOrEmpty(TenantName) ? TenantName : null) ??
            AppState.ActiveTenant?.DisplayName ??
            (_tenants.Count > 0 ? _tenants[0].DisplayName : "");

        AppState.OnChange += OnAppStateChanged;

        if (!string.IsNullOrEmpty(_selectedTenant))
            await LoadAsync();
    }

    private async void OnAppStateChanged()
    {
        if (AppState.ActiveTenant is not null &&
            _selectedTenant != AppState.ActiveTenant.DisplayName)
        {
            _selectedTenant = AppState.ActiveTenant.DisplayName;
            _history = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void OnTenantChanged(ChangeEventArgs e)
    {
        _selectedTenant = e.Value?.ToString() ?? "";
        AppState.SetActiveTenant(_tenants.FirstOrDefault(t => t.DisplayName == _selectedTenant));
        _history = null;
    }

    public void Dispose() => AppState.OnChange -= OnAppStateChanged;

    private async Task LoadAsync()
    {
        if (string.IsNullOrEmpty(_selectedTenant)) return;
        _loading = true;
        _error = null;
        try
        {
            if (SettingsSvc.Settings.AppMode == "cloud")
            {
                var tenant = _tenants.FirstOrDefault(t => t.DisplayName == _selectedTenant);
                if (tenant is null) { _error = $"Tenant \"{_selectedTenant}\" not found."; return; }
                var entries = await DataProvider.GetHistoryAsync(tenant.TenantId);
                _history = entries.ToList();
            }
            else
            {
                var tenant = await TenantRepo.GetTenantAsync(_selectedTenant);
                if (tenant is null) { _error = $"Tenant \"{_selectedTenant}\" not found."; return; }
                var entries = await HistoryRepo.GetHistoryAsync(tenant.TenantId);
                _history = entries.ToList();
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }
}
