@page "/secrets"
@page "/secrets/{TenantName}"
@inject CliExecutionService Cli
@inject TenantConfigRepository TenantRepo
@inject AppStateService AppState
@inject TeamsNotificationService Teams
@implements IDisposable

<PageTitle>Secrets — AARM</PageTitle>

<div class="aarm-page-header">
    <h1>Secrets</h1>

    <select class="form-select" style="max-width:220px" value="@_selectedTenant"
            @onchange="OnTenantChanged">
        <option value="">— Select tenant —</option>
        @foreach (var t in _tenants)
        {
            <option value="@t.DisplayName">@t.DisplayName</option>
        }
    </select>

    <select class="form-select" style="max-width:140px" @bind="_filterRisk">
        <option value="">All risks</option>
        <option value="Critical">Critical</option>
        <option value="High">High</option>
        <option value="Medium">Medium</option>
        <option value="Low">Low</option>
        <option value="Info">Info</option>
    </select>

    <button class="btn btn-primary btn-sm"
            @onclick="LoadAsync"
            disabled="@(string.IsNullOrEmpty(_selectedTenant) || _loading)">
        Scan
    </button>

    @if (Teams.IsConfigured && _secrets is not null)
    {
        <button class="btn btn-outline-secondary btn-sm"
                @onclick="SendAllToTeamsAsync"
                disabled="@_sendingTeams"
                title="Send summary to Teams">
            @(_sendingTeams ? "Sending…" : "📨 Teams")
        </button>
    }
</div>

@if (_loading)
{
    <div class="aarm-loading">Scanning secrets…</div>
}
else if (_error is not null)
{
    <div class="aarm-error">@_error</div>
}
else if (_secrets is null)
{
    <div class="aarm-empty">Select a tenant and click Scan to list secrets.</div>
}
else
{
    var filtered = string.IsNullOrEmpty(_filterRisk)
        ? _secrets
        : _secrets.Where(s => s.RiskLevel == _filterRisk).ToList();

    <p style="color:var(--text-muted);font-size:.8rem;margin-bottom:.75rem">
        @filtered.Count secret(s)
        — @_secrets.Count(s => s.Status == "Expired") expired
        — @_secrets.Count(s => s.Status == "ExpiringSoon") expiring soon
    </p>

    @if (filtered.Count == 0)
    {
        <div class="aarm-empty">No secrets match the current filter.</div>
    }
    else
    {
        <table class="aarm-table">
            <thead>
                <tr>
                    <th>Risk</th>
                    <th>App</th>
                    <th>Secret</th>
                    <th>Expires</th>
                    <th>Days</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in filtered.OrderBy(s => s.DaysUntilExpiry ?? int.MaxValue))
                {
                    var daysClass = s.DaysUntilExpiry < 0 ? "risk-critical"
                                  : s.DaysUntilExpiry <= 30 ? "risk-high"
                                  : s.DaysUntilExpiry <= 90 ? "risk-medium" : "";
                    var statusClass = s.Status == "Expired" ? "risk-critical"
                                    : s.Status == "ExpiringSoon" ? "risk-medium"
                                    : s.Status == "Valid" ? "status-ok" : "";
                    <tr>
                        <td><span class="badge-risk @s.RiskLevel.ToLower()">@s.RiskLevel</span></td>
                        <td>@s.AppDisplayName</td>
                        <td>
                            @(s.DisplayName ?? "—")
                            @if (s.Hint != null)
                            {
                                <small style="color:var(--text-muted)"> (@s.Hint…)</small>
                            }
                        </td>
                        <td>
                            @if (s.EndDateTime != null && DateTimeOffset.TryParse(s.EndDateTime, out var dt))
                            {
                                @dt.ToString("yyyy-MM-dd")
                            }
                            else { <span style="color:var(--text-muted)">—</span> }
                        </td>
                        <td class="@daysClass">@(s.DaysUntilExpiry.HasValue ? s.DaysUntilExpiry.ToString() : "—")</td>
                        <td class="@statusClass">@s.Status</td>
                        <td style="white-space:nowrap">
                            <button class="btn btn-link btn-sm p-0 me-2"
                                    title="Open in Azure Portal"
                                    @onclick="() => OpenPortalAsync(s.AppId)">↗</button>
                            @if (Teams.IsConfigured)
                            {
                                <button class="btn btn-link btn-sm p-0"
                                        title="Send this secret to Teams"
                                        @onclick="() => SendOneToTeamsAsync(s)">📨</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    [Parameter] public string? TenantName { get; set; }

    private IReadOnlyList<TenantProfile> _tenants = Array.Empty<TenantProfile>();
    private string _selectedTenant = "";
    private string _filterRisk = "";
    private bool _loading;
    private bool _sendingTeams;
    private string? _error;
    private List<SecretSummary>? _secrets;

    protected override async Task OnInitializedAsync()
    {
        _tenants = await TenantRepo.ListTenantsAsync();

        // Pre-select from global state, URL parameter or first tenant
        if (AppState.ActiveTenant is not null)
            _selectedTenant = AppState.ActiveTenant.DisplayName;
        else if (!string.IsNullOrEmpty(TenantName))
            _selectedTenant = TenantName;

        AppState.OnChange += OnAppStateChanged;

        if (!string.IsNullOrEmpty(_selectedTenant))
            await LoadAsync();
    }

    private async void OnAppStateChanged()
    {
        if (AppState.ActiveTenant is not null &&
            _selectedTenant != AppState.ActiveTenant.DisplayName)
        {
            _selectedTenant = AppState.ActiveTenant.DisplayName;
            _secrets = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OnTenantChanged(ChangeEventArgs e)
    {
        _selectedTenant = e.Value?.ToString() ?? "";
        var tenant = _tenants.FirstOrDefault(t => t.DisplayName == _selectedTenant);
        AppState.SetActiveTenant(tenant);
        _secrets = null;
    }

    private async Task LoadAsync()
    {
        if (string.IsNullOrEmpty(_selectedTenant)) return;
        _loading = true;
        _error = null;
        try
        {
            var envelope = await Cli.RunAsync<IReadOnlyList<SecretSummary>>(
                _selectedTenant, "secrets", "list");
            _secrets = envelope?.Data?.ToList() ?? new();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private static async Task OpenPortalAsync(string appId) =>
        await Launcher.OpenAsync(
            $"https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps/ApplicationMenuBlade/~/Overview/appId/{appId}");

    private async Task SendAllToTeamsAsync()
    {
        if (_secrets is null) return;
        _sendingTeams = true;
        try { await Teams.SendSecretsReportAsync(_secrets, _selectedTenant); }
        catch { }
        finally { _sendingTeams = false; StateHasChanged(); }
    }

    private async Task SendOneToTeamsAsync(SecretSummary secret)
    {
        try { await Teams.SendSecretStatusAsync(secret, _selectedTenant); }
        catch { }
    }

    public void Dispose() => AppState.OnChange -= OnAppStateChanged;
}
