@page "/secrets"
@page "/secrets/{TenantName}"
@using AzureAppRegistrationMonitor.Services.DataProviders
@inject IDataProvider DataProvider
@inject TenantConfigRepository TenantRepo
@inject AppStateService AppState
@inject TeamsNotificationService Teams
@inject SettingsService SettingsSvc
@implements IDisposable

<PageTitle>Secrets — AARM</PageTitle>

<div class="aarm-page-header">
    <h1>Secrets</h1>

    <select class="form-select" style="max-width:220px" value="@_selectedTenant"
            @onchange="OnTenantChanged">
        <option value="">— Select tenant —</option>
        @foreach (var t in _tenants)
        {
            <option value="@t.DisplayName">@t.DisplayName</option>
        }
    </select>

    <select class="form-select" style="max-width:140px" @bind="_filterRisk">
        <option value="">All risks</option>
        <option value="Critical">Critical</option>
        <option value="High">High</option>
        <option value="Medium">Medium</option>
        <option value="Low">Low</option>
        <option value="Info">Info</option>
    </select>

    <button class="btn btn-primary btn-sm"
            @onclick="LoadAsync"
            disabled="@(string.IsNullOrEmpty(_selectedTenant) || _loading)">
        @(_loading ? "Loading…" : (SettingsSvc.Settings.AppMode == "cloud" ? "↻ Refresh" : "Scan"))
    </button>

    @if (_lastScanAt is not null)
    {
        <span style="color:var(--text-muted);font-size:.8rem">
            Last scan: <strong>@_lastScanAt</strong>
        </span>
    }

    @if (Teams.IsConfigured && _secrets is not null)
    {
        <button class="btn btn-outline-secondary btn-sm"
                @onclick="SendAllToTeamsAsync"
                disabled="@_sendingTeams"
                title="Send summary to Teams">
            @(_sendingTeams ? "Sending…" : "📨 Teams")
        </button>
    }
</div>

@if (_loading)
{
    <div class="aarm-loading">
        Scanning secrets…
        <ProgressLog Lines="_progressLines" />
    </div>
}
else if (_error is not null)
{
    <div class="aarm-error">@_error</div>
}
else if (_secrets is null)
{
    <div class="aarm-empty">Select a tenant and click Scan to list secrets.</div>
}
else
{
    var filtered = string.IsNullOrEmpty(_filterRisk)
        ? _secrets
        : _secrets.Where(s => s.RiskLevel == _filterRisk).ToList();

    <p style="color:var(--text-muted);font-size:.8rem;margin-bottom:.75rem">
        @filtered.Count secret(s)
        — @_secrets.Count(s => s.Status == "Expired") expired
        — @_secrets.Count(s => s.Status == "ExpiringSoon") expiring soon
    </p>

    @if (filtered.Count == 0)
    {
        <div class="aarm-empty">No secrets match the current filter.</div>
    }
    else
    {
        <table class="aarm-table">
            <thead>
                <tr>
                    <th>Risk</th>
                    <th class="@SortClass("app")" @onclick='() => SortBy("app")'>
                        App <span class="sort-icon">@SortIcon("app")</span>
                    </th>
                    <th class="@SortClass("secret")" @onclick='() => SortBy("secret")'>
                        Secret <span class="sort-icon">@SortIcon("secret")</span>
                    </th>
                    <th class="@SortClass("expires")" @onclick='() => SortBy("expires")'>
                        Expires <span class="sort-icon">@SortIcon("expires")</span>
                    </th>
                    <th class="@SortClass("days")" @onclick='() => SortBy("days")'>
                        Days <span class="sort-icon">@SortIcon("days")</span>
                    </th>
                    <th class="@SortClass("status")" @onclick='() => SortBy("status")'>
                        Status <span class="sort-icon">@SortIcon("status")</span>
                    </th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in ApplySort(filtered))
                {
                    var daysClass = s.DaysUntilExpiry < 0 ? "risk-critical"
                                  : s.DaysUntilExpiry <= 30 ? "risk-high"
                                  : s.DaysUntilExpiry <= 90 ? "risk-medium" : "";
                    var statusClass = s.Status == "Expired" ? "risk-critical"
                                    : s.Status == "ExpiringSoon" ? "risk-medium"
                                    : s.Status == "Valid" ? "status-ok" : "";
                    <tr>
                        <td><span class="badge-risk @s.RiskLevel.ToLower()">@s.RiskLevel</span></td>
                        <td>@s.AppDisplayName</td>
                        <td>
                            @(s.DisplayName ?? "—")
                            @if (s.Hint != null)
                            {
                                <small style="color:var(--text-muted)"> (@s.Hint…)</small>
                            }
                        </td>
                        <td>
                            @if (s.EndDateTime != null && DateTimeOffset.TryParse(s.EndDateTime, out var dt))
                            {
                                @dt.ToString("yyyy-MM-dd")
                            }
                            else { <span style="color:var(--text-muted)">—</span> }
                        </td>
                        <td class="@daysClass">@(s.DaysUntilExpiry.HasValue ? s.DaysUntilExpiry.ToString() : "—")</td>
                        <td class="@statusClass">@s.Status</td>
                        <td style="white-space:nowrap">
                            <button class="btn btn-link btn-sm p-0 me-2"
                                    title="Open in Azure Portal"
                                    @onclick="() => OpenPortalAsync(s.AppId)">↗</button>
                            @if (Teams.IsConfigured)
                            {
                                <button class="btn btn-link btn-sm p-0"
                                        title="Send this secret to Teams"
                                        @onclick="() => SendOneToTeamsAsync(s)">📨</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    [Parameter] public string? TenantName { get; set; }

    private IReadOnlyList<TenantProfile> _tenants = Array.Empty<TenantProfile>();
    private string _selectedTenant = "";
    private string _filterRisk = "";
    private bool _loading;
    private bool _sendingTeams;
    private string? _error;
    private string? _lastScanAt;
    private List<SecretSummary>? _secrets;
    private readonly List<string> _progressLines = new();
    private string _sortCol = "days";
    private bool _sortAsc = true;

    protected override async Task OnInitializedAsync()
    {
        _tenants = await DataProvider.GetTenantsAsync();

        // Pre-select from URL, then global AppState, then first tenant
        if (!string.IsNullOrEmpty(TenantName))
            _selectedTenant = TenantName;
        else if (AppState.ActiveTenant is not null)
            _selectedTenant = AppState.ActiveTenant.DisplayName;
        else if (_tenants.Count > 0)
            _selectedTenant = _tenants[0].DisplayName;

        UpdateLastScanLabel();
        AppState.OnChange += OnAppStateChanged;

        // In Cloud Mode: auto-load cached scan results if a tenant is already selected
        if (!string.IsNullOrEmpty(_selectedTenant) && SettingsSvc.Settings.AppMode == "cloud")
            await LoadAsync();
    }

    private async void OnAppStateChanged()
    {
        if (AppState.ActiveTenant is not null &&
            _selectedTenant != AppState.ActiveTenant.DisplayName)
        {
            _selectedTenant = AppState.ActiveTenant.DisplayName;
            _secrets = null;
            UpdateLastScanLabel();
            await InvokeAsync(StateHasChanged);
        }
    }

    private void OnTenantChanged(ChangeEventArgs e)
    {
        _selectedTenant = e.Value?.ToString() ?? "";
        var tenant = _tenants.FirstOrDefault(t => t.DisplayName == _selectedTenant);
        AppState.SetActiveTenant(tenant);
        _secrets = null;
        UpdateLastScanLabel();
    }

    private void UpdateLastScanLabel()
    {
        var tenant = _tenants.FirstOrDefault(t => t.DisplayName == _selectedTenant);
        _lastScanAt = tenant?.LastSuccessfulScanAt is string s
            && DateTimeOffset.TryParse(s, out var dt)
            ? dt.LocalDateTime.ToString("yyyy-MM-dd HH:mm")
            : null;
    }

    private async Task LoadAsync()
    {
        if (string.IsNullOrEmpty(_selectedTenant)) return;
        _loading = true;
        _error = null;
        _progressLines.Clear();
        DataProvider.ProgressMessage += OnProgress;
        try
        {
            var tenant = _tenants.FirstOrDefault(t => t.DisplayName == _selectedTenant);
            var envelope = await DataProvider.GetSecretsAsync(
                tenant?.TenantId ?? _selectedTenant,
                null);
            _secrets = envelope?.Data?.ToList() ?? new();
            _tenants = await DataProvider.GetTenantsAsync();
            UpdateLastScanLabel();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally
        {
            DataProvider.ProgressMessage -= OnProgress;
            _loading = false;
        }
    }

    private void OnProgress(string line)
    {
        if (string.IsNullOrWhiteSpace(line)) return;
        _progressLines.Add(line);
        InvokeAsync(StateHasChanged);
    }

    private void SortBy(string col)
    {
        if (_sortCol == col) _sortAsc = !_sortAsc;
        else { _sortCol = col; _sortAsc = col == "app"; }
    }

    private string SortIcon(string col) => _sortCol != col ? "↕" : (_sortAsc ? "▲" : "▼");
    private string SortClass(string col) => _sortCol == col ? "sortable sort-active" : "sortable";

    private IEnumerable<SecretSummary> ApplySort(IEnumerable<SecretSummary> src) => (_sortCol, _sortAsc) switch
    {
        ("app",     true)  => src.OrderBy(s => s.AppDisplayName),
        ("app",     false) => src.OrderByDescending(s => s.AppDisplayName),
        ("secret",  true)  => src.OrderBy(s => s.DisplayName),
        ("secret",  false) => src.OrderByDescending(s => s.DisplayName),
        ("expires", true)  => src.OrderBy(s => s.EndDateTime ?? "9999"),
        ("expires", false) => src.OrderByDescending(s => s.EndDateTime ?? ""),
        ("status",  true)  => src.OrderBy(s => s.Status),
        ("status",  false) => src.OrderByDescending(s => s.Status),
        ("days",    false) => src.OrderByDescending(s => s.DaysUntilExpiry ?? int.MaxValue),
        _                  => src.OrderBy(s => s.DaysUntilExpiry ?? int.MaxValue),
    };

    private async Task OpenPortalAsync(string appId)
    {
        var tenant = _tenants.FirstOrDefault(t => t.DisplayName == _selectedTenant);
        var tenantSegment = tenant is not null ? $"{tenant.TenantId}/" : "";
        await Launcher.OpenAsync(
            $"https://portal.azure.com/{tenantSegment}#view/Microsoft_AAD_RegisteredApps/ApplicationMenuBlade/~/Overview/appId/{appId}");
    }

    private async Task SendAllToTeamsAsync()
    {
        if (_secrets is null) return;
        _sendingTeams = true;
        try { await Teams.SendSecretsReportAsync(_secrets, _selectedTenant); }
        catch { }
        finally { _sendingTeams = false; StateHasChanged(); }
    }

    private async Task SendOneToTeamsAsync(SecretSummary secret)
    {
        try { await Teams.SendSecretStatusAsync(secret, _selectedTenant); }
        catch { }
    }

    public void Dispose() => AppState.OnChange -= OnAppStateChanged;
}
