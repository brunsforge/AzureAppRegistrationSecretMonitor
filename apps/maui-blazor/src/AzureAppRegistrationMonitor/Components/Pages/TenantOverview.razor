    private void ShowCloudAddForm()
    {
        _cf = new CloudTenantRequest { LogAnalytics = new() };
        _cfTeamsStatus = _cfTeamsAlerts = _cfTeamsErrors = "";
        _cfTplCritical = _cfTplExpiring = _cfTplSummary = _cfTplError = "";
        _cfMailTo = "";
        _cfMailSendExpiring = true; _cfMailSendCritical = true;
        _cfMailSendStatus = false;  _cfMailSendError = true;
        _cfExpiringDays = 30; _cfCriticalDays = 7;
        _cloudEditTenantId = null;
        _cloudFormError    = null;
        _showCloudForm     = true;
    }

    private void ShowCloudEditForm(TenantProfile t)
    {
        _cf = new CloudTenantRequest
        {
            TenantId          = t.TenantId,
            TenantDisplayName = t.DisplayName,
            AuthMode          = t.AuthMode,
            ClientId          = t.ClientId,
            LogAnalytics      = new() { WorkspaceId = t.LogAnalyticsWorkspaceId },
        };
        _cfTeamsStatus = _cfTeamsAlerts = _cfTeamsErrors = "";
        _cfTplCritical = _cfTplExpiring = _cfTplSummary = _cfTplError = "";
        _cfMailTo = "";
        _cfMailSendExpiring = true; _cfMailSendCritical = true;
        _cfMailSendStatus = false;  _cfMailSendError = true;
        _cfExpiringDays = 30; _cfCriticalDays = 7;
        _cloudEditTenantId = t.TenantId;
        _cloudFormError    = null;
        _showCloudForm     = true;
    }

    private void CancelCloudForm()
    {
        _showCloudForm  = false;
        _cloudFormError = null;
    }

    private async Task SaveCloudTenantAsync()
    {
        _cloudFormError = null;
        if (string.IsNullOrWhiteSpace(_cf.TenantId))          { _cloudFormError = "Tenant ID is required."; return; }
        if (string.IsNullOrWhiteSpace(_cf.TenantDisplayName)) { _cloudFormError = "Display name is required."; return; }
        if (_cf.AuthMode == "client-secret")
        {
            if (string.IsNullOrWhiteSpace(_cf.ClientId)) { _cloudFormError = "Client ID is required."; return; }
            if (_cloudEditTenantId is null && string.IsNullOrWhiteSpace(_cf.CredentialValue))
            { _cloudFormError = "Client Secret is required for new tenants."; return; }
        }

        _cf.TeamsWebhooks = new()
        {
            Status  = string.IsNullOrWhiteSpace(_cfTeamsStatus)  ? null : _cfTeamsStatus,
            Alerts  = string.IsNullOrWhiteSpace(_cfTeamsAlerts)  ? null : _cfTeamsAlerts,
            Errors  = string.IsNullOrWhiteSpace(_cfTeamsErrors)  ? null : _cfTeamsErrors,
        };
        _cf.NotificationTemplates = new()
        {
            Critical     = string.IsNullOrWhiteSpace(_cfTplCritical) ? null : _cfTplCritical,
            Expiring     = string.IsNullOrWhiteSpace(_cfTplExpiring) ? null : _cfTplExpiring,
            Summary      = string.IsNullOrWhiteSpace(_cfTplSummary)  ? null : _cfTplSummary,
            Error        = string.IsNullOrWhiteSpace(_cfTplError)    ? null : _cfTplError,
        };
        _cf.NotificationThresholds = new()
        {
            ExpiringWithinDays = _cfExpiringDays,
            CriticalWithinDays = _cfCriticalDays,
        };
        var mailAddresses = _cfMailTo
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .ToList();
        _cf.MailTargets = mailAddresses.Count > 0 ? new()
        {
            To              = mailAddresses,
            SendOnExpiring  = _cfMailSendExpiring,
            SendOnCritical  = _cfMailSendCritical,
            SendOnStatus    = _cfMailSendStatus,
            SendOnError     = _cfMailSendError,
        } : null;

        _cloudSaving = true;
        try
        {
            TenantProfile? result = _cloudEditTenantId is null
                ? await DataProvider.AddTenantAsync(_cf)
                : await DataProvider.UpdateTenantAsync(_cloudEditTenantId, _cf);

            Notify.Show(
                _cloudEditTenantId is null ? "Tenant added" : "Tenant updated",
                $"\"{_cf.TenantDisplayName}\" saved. Credential stored in Azure Key Vault.");

            _showCloudForm = false;
            await LoadAsync();
        }
        catch (Exception ex) { _cloudFormError = ex.Message; }
        finally { _cloudSaving = false; }
    }

    private async Task TriggerCloudScanAsync(TenantProfile tenant)
    {
        _triggeringTenantId = tenant.TenantId;
        _scanMessage = null;
        StateHasChanged();
        try
        {
            var accepted = await DataProvider.TriggerScanAsync(tenant.TenantId);
            _scanMessage = accepted
                ? $"✓ Scan triggered for \"{tenant.DisplayName}\". Results will be available in a few seconds — refresh the Secrets or Preflight page."
                : $"✗ Scan trigger rejected for \"{tenant.DisplayName}\".";
        }
        catch (Exception ex)
        {
            _scanMessage = $"✗ {ex.Message}";
        }
        finally
        {
            _triggeringTenantId = null;
            StateHasChanged();
        }
    }

