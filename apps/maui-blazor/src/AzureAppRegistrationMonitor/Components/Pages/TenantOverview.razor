        _fDisplayName   = "";
        _fTenantId      = "";
        _fAuthMode      = "interactive-browser";
        _fClientId      = "";
        _fClientSecret  = "";
        _fUsername      = "";
        _fPassword      = "";
        _fWorkspaceId   = "";
        _formError      = null;
    }

