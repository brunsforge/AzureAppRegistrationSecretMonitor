@page "/preflight"
@page "/preflight/{TenantName}"
@using AzureAppRegistrationMonitor.Services.DataProviders
@inject IDataProvider DataProvider
@inject TenantConfigRepository TenantRepo
@inject AppStateService AppState
@inject SettingsService SettingsSvc
@implements IDisposable

<PageTitle>Preflight — AARM</PageTitle>

<div class="aarm-page-header">
    <h1>Preflight Check</h1>

    <select class="form-select" style="max-width:220px"
            value="@_selectedTenant" @onchange="OnTenantChanged">
        <option value="">— Select tenant —</option>
        @foreach (var t in _tenants)
        {
            <option value="@t.DisplayName">@t.DisplayName</option>
        }
    </select>

    <button class="btn btn-primary btn-sm"
            @onclick="RunPreflightAsync"
            disabled="@(string.IsNullOrEmpty(_selectedTenant) || _loading)">
        @if (_loading)
        {
            @(_scanPhase == "trigger" ? "Triggering scan…" : _scanPhase == "wait" ? "Waiting for result…" : "Running…")
        }
        else
        {
            @(SettingsSvc.Settings.AppMode == "cloud" ? "↻ Trigger scan + preflight" : "↻ Run preflight")
        }
    </button>
</div>

@if (_loading)
{
    <div class="aarm-loading">
        Running capability checks…
        <ProgressLog Lines="_progressLines" />
    </div>
}
else if (_error is not null)
{
    <div class="aarm-error">@_error</div>
}
else if (_result is null)
{
    <div class="aarm-empty">
        @if (SettingsSvc.Settings.AppMode == "cloud")
        {
            <p>No preflight data yet for this tenant.</p>
            <p style="font-size:.82rem;color:var(--text-muted);margin-top:.5rem">
                Click <strong>↻ Trigger scan + preflight</strong> to run the first scan.
                This also validates credentials — if the tenant ID, Client ID or secret
                are wrong, the preflight result will show <strong>Auth FAILED</strong>.
            </p>
        }
        else
        {
            <p>Select a tenant and click <strong>Run preflight</strong> to check which permissions are available.</p>
            <p style="font-size:.82rem;color:var(--text-muted);margin-top:.5rem">
                Preflight tests each capability individually against the real Entra API
                and reports exactly which permissions are missing.
            </p>
        }
    </div>
}
else
{
    <div class="aarm-preflight-header">
        <div class="aarm-status-badge @(_result.AuthValid ? "ok" : "fail")">
            Auth @(_result.AuthValid ? "OK" : "FAILED")
        </div>
        <div class="aarm-status-badge @(_result.GraphReachable ? "ok" : "fail")">
            Graph @(_result.GraphReachable ? "reachable" : "unreachable")
        </div>
        <small style="color:var(--text-muted)">
            Checked @(DateTimeOffset.TryParse(_result.CheckedAt, out var dt)
                ? dt.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss")
                : _result.CheckedAt)
        </small>
    </div>

    @if (!_result.AuthValid)
    {
        <div class="aarm-error" style="margin-top:.75rem;font-size:.85rem">
            <strong>Authentication failed.</strong>
            Possible causes: wrong Tenant ID, wrong Client ID, expired or invalid Client Secret,
            or missing App Registration in the target tenant.
            @if (_result.Errors.Any())
            {
                <ul style="margin:.5rem 0 0;padding-left:1.2rem">
                    @foreach (var e in _result.Errors)
                    {
                        <li>@e</li>
                    }
                </ul>
            }
        </div>
    }

    <h3 style="font-size:.95rem;font-weight:600;margin-top:1.25rem;margin-bottom:.5rem">
        Capabilities (@GetEnabledCount() / @TotalCapabilities enabled)
    </h3>
    <table class="aarm-capabilities-table">
        <tbody>
            @foreach (var cap in GetCapabilities())
            {
                <tr>
                    <td style="width:24px;padding:.3rem .5rem">
                        <span class="@(cap.Value ? "cap-ok" : "cap-fail")" style="font-size:1rem">
                            @(cap.Value ? "✓" : "○")
                        </span>
                    </td>
                    <td style="padding:.3rem .5rem;font-family:monospace;font-size:.82rem;color:var(--text)">
                        @cap.Key
                    </td>
                    <td style="padding:.3rem .5rem;font-size:.78rem;color:var(--text-muted)">
                        @(cap.Value ? "" : "unavailable")
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (_result.MissingPermissions.Any())
    {
        <h3 style="font-size:.95rem;font-weight:600;margin-top:1.25rem;margin-bottom:.5rem">
            Missing permissions
        </h3>
        <ul style="list-style:none;padding:0;margin:0">
            @foreach (var p in _result.MissingPermissions)
            {
                <li style="padding:.3rem 0;border-bottom:1px solid var(--border);font-size:.8rem;color:var(--risk-high)">
                    ✗ @p
                </li>
            }
        </ul>
        <p style="margin-top:.75rem;font-size:.8rem;color:var(--text-muted)">
            Run <code>aarm --tenant "@_selectedTenant" preflight explain</code> for detailed grant instructions.
        </p>
    }

    @if (_result.Warnings.Any())
    {
        <h3 style="font-size:.95rem;font-weight:600;margin-top:1.25rem;margin-bottom:.5rem">Warnings</h3>
        @foreach (var w in _result.Warnings)
        {
            <p style="font-size:.82rem;color:var(--risk-medium);margin:.2rem 0">⚠ @w</p>
        }
    }
}

@code {
    [Parameter] public string? TenantName { get; set; }

    private IReadOnlyList<TenantProfile> _tenants = Array.Empty<TenantProfile>();
    private string _selectedTenant = "";
    private bool _loading;
    private string? _error;
    private PreflightResult? _result;
    private readonly List<string> _progressLines = new();
    private string _scanPhase = "";

    private static int TotalCapabilities => 12;
    private int GetEnabledCount() => _result is null ? 0 : GetCapabilities().Count(c => c.Value);

    protected override async Task OnInitializedAsync()
    {
        _tenants = await DataProvider.GetTenantsAsync();

        _selectedTenant =
            (!string.IsNullOrEmpty(TenantName) ? TenantName : null) ??
            AppState.ActiveTenant?.DisplayName ??
            (_tenants.Count > 0 ? _tenants[0].DisplayName : "");

        AppState.OnChange += OnAppStateChanged;

        // Auto-load cached result; only run live if navigated via deep link
        if (!string.IsNullOrEmpty(_selectedTenant))
            await LoadCachedAsync();

        if (!string.IsNullOrEmpty(TenantName) && _result is null)
            await RunPreflightAsync();
    }

    private async void OnAppStateChanged()
    {
        if (AppState.ActiveTenant is not null &&
            _selectedTenant != AppState.ActiveTenant.DisplayName)
        {
            _selectedTenant = AppState.ActiveTenant.DisplayName;
            _result = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadCachedAsync()
    {
        try
        {
            var tenant = _tenants.FirstOrDefault(t => t.DisplayName == _selectedTenant);
            if (tenant is null) return;
            var envelope = await DataProvider.GetPreflightAsync(tenant.TenantId, null);
            _result = envelope?.Data;
        }
        catch { /* no cached data */ }
    }

    private void OnTenantChanged(ChangeEventArgs e)
    {
        _selectedTenant = e.Value?.ToString() ?? "";
        AppState.SetActiveTenant(_tenants.FirstOrDefault(t => t.DisplayName == _selectedTenant));
        _result = null;
        _ = LoadCachedAsync();
    }

    public void Dispose() => AppState.OnChange -= OnAppStateChanged;

    private async Task RunPreflightAsync()
    {
        if (string.IsNullOrEmpty(_selectedTenant)) return;
        _loading = true;
        _error = null;
        _result = null;
        _progressLines.Clear();
        DataProvider.ProgressMessage += OnProgress;
        try
        {
            var tenant = _tenants.FirstOrDefault(t => t.DisplayName == _selectedTenant);
            var tenantId = tenant?.TenantId ?? _selectedTenant;

            if (SettingsSvc.Settings.AppMode == "cloud")
            {
                // Cloud: trigger scan (runs preflight + secrets), then poll for result
                _scanPhase = "trigger";
                StateHasChanged();
                await DataProvider.TriggerScanAsync(tenantId);

                _scanPhase = "wait";
                StateHasChanged();

                // Poll up to 90s for the preflight result to appear
                var deadline = DateTime.UtcNow.AddSeconds(90);
                while (DateTime.UtcNow < deadline)
                {
                    await Task.Delay(4000);
                    var env = await DataProvider.GetPreflightAsync(tenantId, null);
                    if (env?.Data is not null)
                    {
                        _result = env.Data;
                        break;
                    }
                }
                if (_result is null)
                    _error = "Scan triggered but no preflight result available after 90s. Check App Insights for errors.";
            }
            else
            {
                _scanPhase = "";
                var envelope = await DataProvider.GetPreflightAsync(tenantId, null);
                _result = envelope?.Data;
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally
        {
            DataProvider.ProgressMessage -= OnProgress;
            _loading = false;
            _scanPhase = "";
        }
    }

    private void OnProgress(string line)
    {
        if (string.IsNullOrWhiteSpace(line)) return;
        _progressLines.Add(line);
        InvokeAsync(StateHasChanged);
    }

    private IEnumerable<KeyValuePair<string, bool>> GetCapabilities()
    {
        if (_result is null) yield break;
        var c = _result.Capabilities;
        yield return new("canReadApplications",             c.CanReadApplications);
        yield return new("canReadApplicationSecrets",       c.CanReadApplicationSecrets);
        yield return new("canReadServicePrincipals",        c.CanReadServicePrincipals);
        yield return new("canReadOwners",                   c.CanReadOwners);
        yield return new("canReadDirectory",                c.CanReadDirectory);
        yield return new("canQueryLogAnalytics",            c.CanQueryLogAnalytics);
        yield return new("canAnalyzeServicePrincipalSignIns", c.CanAnalyzeServicePrincipalSignIns);
        yield return new("canCreateApplicationSecrets",     c.CanCreateApplicationSecrets);
        yield return new("canDeleteApplicationSecrets",     c.CanDeleteApplicationSecrets);
        yield return new("canCreateApplications",           c.CanCreateApplications);
        yield return new("canReadAzureResources",           c.CanReadAzureResources);
        yield return new("canReadKeyVaultMetadata",         c.CanReadKeyVaultMetadata);
    }
}
