@page "/settings"
@using AzureAppRegistrationMonitor.Services.DataProviders
@using System.Text.Json
@inject TenantConfigRepository TenantRepo
@inject SettingsService SettingsSvc
@inject TeamsNotificationService Teams
@inject DelegatingDataProvider DataProviderProxy
@inject CredentialRepository CredRepo
@inject LocalCliDataProvider LocalProvider

<PageTitle>Settings — AARM</PageTitle>

<div class="aarm-page-header">
    <h1>Settings</h1>
</div>

@if (_saved)
{
    <div class="alert alert-success py-2 mb-3" style="font-size:.85rem">Settings saved.</div>
}

<!-- ── Data Source (Cloud / Local mode) ─────────────────────────────────── -->
<section class="settings-section">
    <h2>Data Source</h2>
    <p class="text-muted" style="font-size:.8rem">
        Local mode uses the bundled CLI. Cloud mode fetches data from your AARM Azure Function.
    </p>

    <div class="settings-row">
        <label>Mode</label>
        <div class="d-flex gap-3">
            <label class="d-flex align-items-center gap-1" style="cursor:pointer">
                <input type="radio" name="appMode" value="local"
                       checked="@(SettingsSvc.Settings.AppMode == "local")"
                       @onchange="SelectLocalMode" />
                Local (CLI)
            </label>
            <label class="d-flex align-items-center gap-1" style="cursor:pointer">
                <input type="radio" name="appMode" value="cloud"
                       checked="@(SettingsSvc.Settings.AppMode == "cloud")"
                       @onchange="SelectCloudMode" />
                Cloud (Azure Function)
            </label>
        </div>
    </div>

    @if (SettingsSvc.Settings.AppMode == "cloud")
    {
        <div class="settings-row">
            <label>Function base URI</label>
            <input class="form-control" style="max-width:480px"
                   placeholder="https://aarm-fn.azurewebsites.net"
                   @bind="SettingsSvc.Settings.CloudBaseUri" />
            <small>Base URL of the AARM Azure Function app.</small>
        </div>

        <div class="settings-row">
            <label>Function key</label>
            <div class="d-flex gap-2" style="max-width:480px">
                <input type="password" class="form-control"
                       placeholder="Paste function key…"
                       @bind="_cloudFunctionKeyInput" />
                <button class="btn btn-outline-secondary btn-sm"
                        @onclick="SaveFunctionKeyAsync">Save key</button>
            </div>
            <small>Stored in Windows Credential Manager — never in plain files.</small>
        </div>

        <div class="d-flex gap-2 mt-2 align-items-center">
            <button class="btn btn-outline-secondary btn-sm"
                    @onclick="TestConnectionAsync"
                    disabled="@_testingConnection">
                @(_testingConnection ? "Testing…" : "Test connection")
            </button>
            @if (_connectionResult is not null)
            {
                <span style="font-size:.85rem;color:@(_connectionOk ? "var(--color-ok)" : "var(--color-error)")">
                    @_connectionResult
                </span>
            }
        </div>
    }

    <button class="btn btn-primary btn-sm mt-3" @onclick="SaveAsync">Save data source settings</button>
</section>

<!-- ── Diagnostics (read-only) ──────────────────────────────────────────── -->
<section class="settings-section">
    <h2>Diagnostics</h2>

    @if (SettingsSvc.Settings.AppMode != "cloud")
    {
        <table style="font-size:.8rem;border-collapse:collapse;width:100%">
            <tr><td style="padding:.25rem .5rem;color:var(--text-muted);width:200px">Config directory</td>
                <td><code>@_configDir</code></td></tr>
            <tr><td style="padding:.25rem .5rem;color:var(--text-muted)">History directory</td>
                <td><code>@Path.Combine(_configDir, "history")</code></td></tr>
            <tr><td style="padding:.25rem .5rem;color:var(--text-muted)">Tenant profiles file</td>
                <td><code>@Path.Combine(_configDir, "tenants.json")</code></td></tr>
            <tr><td style="padding:.25rem .5rem;color:var(--text-muted)">MSAL cache file</td>
                <td><code>@Path.Combine(_configDir, "msal.cache")</code></td></tr>
            <tr><td style="padding:.25rem .5rem;color:var(--text-muted)">History file count</td>
                <td>@_historyFileCount file(s)</td></tr>
        </table>
    }
    else
    {
        <table style="font-size:.8rem;border-collapse:collapse;width:100%">
            <tr><td style="padding:.25rem .5rem;color:var(--text-muted);width:200px">Function URI</td>
                <td><code>@(SettingsSvc.Settings.CloudBaseUri is { Length: > 0 } u ? u : "—")</code></td></tr>
            <tr><td style="padding:.25rem .5rem;color:var(--text-muted)">Connection status</td>
                <td style="color:@(_connectionOk ? "var(--color-ok)" : "var(--text-muted)")">
                    @(_connectionResult ?? "Not tested yet")</td></tr>
            <tr><td style="padding:.25rem .5rem;color:var(--text-muted)">Enabled jobs</td>
                <td>@(_enabledJobCount?.ToString() ?? "—")</td></tr>
        </table>
    }
</section>

<!-- ── UI Preferences ────────────────────────────────────────────────────── -->
<section class="settings-section">
    <h2>UI Preferences</h2>

    <div class="settings-row">
        <label>Default tenant</label>
        <select class="form-select" style="max-width:240px" @bind="SettingsSvc.Settings.DefaultTenant">
            <option value="">— none —</option>
            @foreach (var t in _tenants)
            {
                <option value="@t.DisplayName">@t.DisplayName</option>
            }
        </select>
        <small>Pre-selected in dropdowns when the app opens.</small>
    </div>

    <div class="settings-row">
        <label>Default auth mode for new tenants</label>
        <select class="form-select" style="max-width:240px" @bind="SettingsSvc.Settings.DefaultAuthMode">
            <option value="interactive-browser">interactive-browser (opens browser — supports MFA)</option>
            <option value="device-code">device-code (enter code at microsoft.com/devicelogin — supports MFA)</option>
            <option value="azure-cli">azure-cli (reuse az login session)</option>
            <option value="client-secret">client-secret (service principal, configure via CLI)</option>
            <option value="username-password">username-password (no MFA — configure via CLI)</option>
            <option value="certificate">certificate (configure via CLI)</option>
        </select>
        <small>Pre-selected when adding a tenant from within the UI.</small>
    </div>

    <div class="settings-row">
        <label>CLI path override <em>(development)</em></label>
        <input class="form-control" style="max-width:480px"
               placeholder="Leave empty for auto-detect — e.g. C:\...\packages\cli\dist\index.js"
               @bind="SettingsSvc.Settings.CliPathOverride" />
        <small>Equivalent to the <code>AARM_CLI_PATH</code> environment variable.</small>
    </div>

    <button class="btn btn-primary btn-sm" @onclick="SaveAsync">Save preferences</button>
</section>

<!-- ── Teams Notifications ────────────────────────────────────────────────── -->
<section class="settings-section">
    <h2>Teams Notifications</h2>
    <p class="text-muted" style="font-size:.8rem">
        Configure an incoming webhook URL to send secret reports or status updates to a Teams channel.
        Create the webhook in Teams → Channel → Connectors → Incoming Webhook.
    </p>

    <div class="settings-row">
        <label>Incoming webhook URL</label>
        <input class="form-control" style="max-width:600px"
               placeholder="https://…webhook.office.com/webhookb2/…"
               @bind="SettingsSvc.Settings.TeamsWebhookUrl" />
        <small>Leave empty to disable Teams notifications. The URL is stored in <code>~/.aarm/ui-settings.json</code>.</small>
    </div>

    @if (!string.IsNullOrWhiteSpace(SettingsSvc.Settings.TeamsWebhookUrl))
    {
        <button class="btn btn-outline-secondary btn-sm" @onclick="TestTeamsAsync">
            @(_testingTeams ? "Sending…" : "Test webhook")
        </button>
        @if (_teamsTestResult is not null)
        {
            <span class="ms-2" style="font-size:.85rem;color:@(_teamsTestOk ? "var(--color-ok)" : "var(--color-error)")">
                @_teamsTestResult
            </span>
        }
    }

    <button class="btn btn-primary btn-sm mt-2" @onclick="SaveAsync">Save preferences</button>
</section>

<!-- ── Configured Tenants ────────────────────────────────────────────────── -->
<section class="settings-section">
    <h2>Configured tenants</h2>
    @if (SettingsSvc.Settings.AppMode == "cloud")
    {
        <div style="font-size:.82rem;color:var(--text-muted);margin-bottom:.75rem">
            Cloud Mode — tenants are configured via <code>jobs.json</code> in Azure Blob Storage.
            Credentials are stored in Azure Key Vault.
            Auth mode changes must be made in the job configuration.
            <a href="https://portal.azure.com" target="_blank" rel="noopener"
               style="color:var(--accent);margin-left:.4rem">Open Azure Portal ↗</a>
        </div>
    }
    else
    {
        <p class="text-muted" style="font-size:.8rem">
            Auth modes that require passwords (<code>client-secret</code>, <code>username-password</code>,
            <code>certificate</code>) must be configured or reconfigured via the <code>aarm</code> CLI.
            Non-secret modes can be changed here directly.
        </p>
    }

    @if (_tenants.Count == 0)
    {
        <div class="aarm-empty">No tenants configured. Run <code>aarm tenants add</code> to add one.</div>
    }
    else
    {
        <table class="aarm-table">
            <thead>
                <tr><th>Name</th><th>Tenant ID</th><th>Auth Mode</th><th>Client ID</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var t in _tenants)
                {
                    var editing = _editingTenant == t.TenantId;
                    <tr>
                        <td><strong>@t.DisplayName</strong></td>
                        <td><code>@t.TenantId</code></td>
                        <td>
                            @if (editing)
                            {
                                <select class="form-select form-select-sm" style="max-width:220px"
                                        @bind="_editAuthMode">
                                    <option value="interactive-browser">interactive-browser</option>
                                    <option value="device-code">device-code</option>
                                    <option value="azure-cli">azure-cli</option>
                                </select>
                                <small class="d-block mt-1" style="color:var(--text-muted)">
                                    Password-bearing modes (client-secret, certificate, username-password) require CLI reconfiguration.
                                </small>
                            }
                            else
                            {
                                @t.AuthMode
                            }
                        </td>
                        <td><code style="font-size:.78rem">@(t.ClientId ?? "—")</code></td>
                        <td>
                            @if (editing)
                            {
                                <button class="btn btn-sm btn-primary me-1" @onclick="() => SaveAuthModeAsync(t.TenantId)">Save</button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="CancelEdit">Cancel</button>
                            }
                            else if (SettingsSvc.Settings.AppMode == "cloud")
                            {
                                <a href="https://portal.azure.com" target="_blank" rel="noopener"
                                   style="font-size:.8rem;color:var(--accent)">Manage in Azure ↗</a>
                            }
                            else if (IsNonSecretMode(t.AuthMode))
                            {
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => StartEdit(t.TenantId, t.AuthMode)">Change mode</button>
                            }
                            else
                            {
                                <span style="color:var(--text-dim);font-size:.8rem">Use CLI to change</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <div class="mt-3" style="font-size:.8rem;color:var(--text-muted)">
        To add or remove tenants, or to configure secret-based modes, use the CLI:<br />
        <code>aarm tenants add</code> &nbsp;·&nbsp;
        <code>aarm tenants remove "Name"</code>
    </div>
</section>

@code {
    private List<TenantProfile> _tenants = new();
    private string? _editingTenant;
    private string _editAuthMode = "interactive-browser";
    private bool _saved;
    private bool _testingTeams;
    private string? _teamsTestResult;
    private bool _teamsTestOk;

    // ── Cloud Mode ─────────────────────────────────────────────────────────────
    private string _cloudFunctionKeyInput = "";
    private bool _testingConnection;
    private string? _connectionResult;
    private bool _connectionOk;
    private int? _enabledJobCount;

    // ── Diagnostics ────────────────────────────────────────────────────────────
    private string _configDir = "";
    private int _historyFileCount;

    protected override async Task OnInitializedAsync()
    {
        _tenants = (await TenantRepo.ListTenantsAsync()).ToList();
        _configDir = Path.Combine(
            Environment.GetEnvironmentVariable("AARM_CONFIG_DIR") ??
            Environment.GetFolderPath(Environment.SpecialFolder.UserProfile),
            ".aarm");
        var historyDir = Path.Combine(_configDir, "history");
        _historyFileCount = Directory.Exists(historyDir)
            ? Directory.GetFiles(historyDir, "*.json", SearchOption.AllDirectories).Length
            : 0;
    }

    private Task SelectLocalMode(ChangeEventArgs _) => OnModeChanged("local");
    private Task SelectCloudMode(ChangeEventArgs _) => OnModeChanged("cloud");

    private async Task OnModeChanged(string mode)
    {
        SettingsSvc.Settings.AppMode = mode;
        await SettingsSvc.SaveAsync();

        if (mode == "cloud")
        {
            var uri = SettingsSvc.Settings.CloudBaseUri;
            var key = CredRepo.GetCloudFunctionKey() ?? "";
            if (!string.IsNullOrEmpty(uri) && !string.IsNullOrEmpty(key))
                DataProviderProxy.SetProvider(new CloudHttpDataProvider(uri, key));
        }
        else
        {
            DataProviderProxy.SetProvider(LocalProvider);
        }
        StateHasChanged();
    }

    private async Task SaveFunctionKeyAsync()
    {
        if (!string.IsNullOrWhiteSpace(_cloudFunctionKeyInput))
        {
            CredRepo.SetCloudFunctionKey(_cloudFunctionKeyInput);
            _cloudFunctionKeyInput = "";
            _saved = true;
            await Task.Delay(1500);
            _saved = false;
            StateHasChanged();
        }
    }

    private async Task TestConnectionAsync()
    {
        var uri = SettingsSvc.Settings.CloudBaseUri;
        var key = CredRepo.GetCloudFunctionKey() ?? "";
        if (string.IsNullOrEmpty(uri)) { _connectionResult = "✗ Function URI not set."; _connectionOk = false; return; }
        if (string.IsNullOrEmpty(key)) { _connectionResult = "✗ Function key not saved."; _connectionOk = false; return; }

        _testingConnection = true;
        _connectionResult = null;
        StateHasChanged();
        try
        {
            using var http = new System.Net.Http.HttpClient { Timeout = TimeSpan.FromSeconds(10) };
            http.DefaultRequestHeaders.Add("x-functions-key", key);
            var sw = System.Diagnostics.Stopwatch.StartNew();
            var resp = await http.GetAsync(uri.TrimEnd('/') + "/api/status");
            sw.Stop();
            if (resp.IsSuccessStatusCode)
            {
                var json = await resp.Content.ReadAsStringAsync();
                using var doc = JsonDocument.Parse(json);
                _enabledJobCount = doc.RootElement.TryGetProperty("enabledJobCount", out var el) ? el.GetInt32() : null;
                _connectionResult = $"✓ OK — {sw.ElapsedMilliseconds}ms, {_enabledJobCount} job(s) enabled";
                _connectionOk = true;
            }
            else
            {
                _connectionResult = $"✗ HTTP {(int)resp.StatusCode}";
                _connectionOk = false;
            }
        }
        catch (Exception ex)
        {
            _connectionResult = $"✗ {ex.Message}";
            _connectionOk = false;
        }
        finally
        {
            _testingConnection = false;
            StateHasChanged();
        }
    }

    private async Task SaveAsync()
    {
        await SettingsSvc.SaveAsync();
        _saved = true;
        await Task.Delay(2000);
        _saved = false;
        StateHasChanged();
    }

    private void StartEdit(string tenantId, string currentMode)
    {
        _editingTenant = tenantId;
        _editAuthMode  = IsNonSecretMode(currentMode) ? currentMode : "interactive-browser";
    }

    private void CancelEdit() => _editingTenant = null;

    private async Task SaveAuthModeAsync(string tenantId)
    {
        await TenantRepo.UpdateAuthModeAsync(tenantId, _editAuthMode);
        _tenants = (await TenantRepo.ListTenantsAsync()).ToList();
        _editingTenant = null;
    }

    private static bool IsNonSecretMode(string mode) =>
        mode is "interactive-browser" or "device-code" or "azure-cli";

    private async Task TestTeamsAsync()
    {
        await SettingsSvc.SaveAsync();
        _testingTeams = true;
        _teamsTestResult = null;
        StateHasChanged();
        try
        {
            await Teams.SendSecretsReportAsync(
                Array.Empty<AzureAppRegistrationMonitor.Models.SecretSummary>(),
                "Test — AARM");
            _teamsTestOk = true;
            _teamsTestResult = "✓ Message sent successfully.";
        }
        catch (Exception ex)
        {
            _teamsTestOk = false;
            _teamsTestResult = $"✗ {ex.Message}";
        }
        finally
        {
            _testingTeams = false;
            StateHasChanged();
        }
    }
}
