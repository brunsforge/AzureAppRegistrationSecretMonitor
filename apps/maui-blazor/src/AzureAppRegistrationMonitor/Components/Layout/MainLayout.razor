@inherits LayoutComponentBase
@inject AppInitializationService InitSvc
@inject SettingsService SettingsSvc
@inject NavigationManager Nav

<div class="aarm-layout">
    <nav class="aarm-sidebar">
        <div class="aarm-sidebar-brand">
            <span class="aarm-brand-icon">🔑</span>
            <span class="aarm-brand-name">AARM</span>
            <span class="aarm-mode-badge"
                  title="@(SettingsSvc.Settings.AppMode == "cloud" ? "Cloud Mode" : "Local Mode")">
                @(SettingsSvc.Settings.AppMode == "cloud" ? "☁" : "💻")
            </span>
        </div>
        <ul class="aarm-nav">
            <li>
                <NavLink href="/" Match="NavLinkMatch.All">
                    <span>🏠</span> Tenants
                </NavLink>
            </li>
            <li>
                <NavLink href="/dashboard">
                    <span>📊</span> Dashboard
                </NavLink>
            </li>
            <li>
                <NavLink href="/secrets">
                    <span>🔑</span> Secrets
                </NavLink>
            </li>
            <li>
                <NavLink href="/preflight">
                    <span>✅</span> Preflight
                </NavLink>
            </li>
            <li>
                <NavLink href="/history">
                    <span>📋</span> History
                </NavLink>
            </li>
            <li>
                <NavLink href="/settings">
                    <span>⚙️</span> Settings
                </NavLink>
            </li>
        </ul>
    </nav>

    <main class="aarm-main">
        <ErrorBoundary>
            <ChildContent>@Body</ChildContent>
            <ErrorContent Context="ex">
                <div class="aarm-error">
                    <h3>Something went wrong</h3>
                    <pre>@ex.Message</pre>
                </div>
            </ErrorContent>
        </ErrorBoundary>
    </main>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        // Yield once to let AppInitializationService.InitializeAsync() complete.
        await Task.Yield();
        if (InitSvc.SetupRequired && !Nav.Uri.Contains("/startup"))
            Nav.NavigateTo("/startup", replace: true);
    }
}
