@inherits LayoutComponentBase
@inject AppInitializationService InitSvc
@inject SettingsService SettingsSvc
@inject NavigationManager Nav
@inject AppStateService AppState

<div class="aarm-layout">
    <nav class="aarm-sidebar">
        <div class="aarm-sidebar-brand">
            <span class="aarm-brand-icon">🔑</span>
            <span class="aarm-brand-name">AARM</span>
        </div>
        <div class="aarm-mode-banner @(SettingsSvc.Settings.AppMode == "cloud" ? "aarm-mode-cloud" : "aarm-mode-local")"
             title="@(SettingsSvc.Settings.AppMode == "cloud" ? "Cloud Mode — data from Azure Function" : "Local Mode — CLI on this machine")">
            @(SettingsSvc.Settings.AppMode == "cloud" ? "☁ Cloud Mode" : "💻 Local Mode")
        </div>
        <ul class="aarm-nav">
            <li>
                <NavLink href="/" Match="NavLinkMatch.All">
                    <span>🏠</span> Tenants
                </NavLink>
            </li>
            <li>
                <NavLink href="/dashboard">
                    <span>📊</span> Dashboard
                </NavLink>
            </li>
            <li>
                <NavLink href="/secrets">
                    <span>🔑</span> Secrets
                </NavLink>
            </li>
            <li>
                <NavLink href="/preflight">
                    <span>✅</span> Preflight
                </NavLink>
            </li>
            <li>
                <NavLink href="/history">
                    <span>📋</span> History
                </NavLink>
            </li>
            <li>
                <NavLink href="/template-preview">
                    <span>🎨</span> Templates
                </NavLink>
            </li>
            <li>
                <NavLink href="/settings">
                    <span>⚙️</span> Settings
                </NavLink>
            </li>
            @if (SettingsSvc.Settings.AppMode == "cloud" && !string.IsNullOrWhiteSpace(SettingsSvc.Settings.CloudBaseUri))
            {
                var baseUrl = SettingsSvc.Settings.CloudBaseUri.TrimEnd('/');
                var activeTenantId = AppState.ActiveTenant?.TenantId ?? "";
                <li style="border-top:1px solid var(--border);margin-top:auto;padding-top:.25rem">
                    <a href="@baseUrl/api/dashboard"
                       target="_blank" rel="noopener"
                       title="Interactive dashboard — live data via fetch()"
                       style="display:flex;align-items:center;gap:.5rem;padding:.5rem 1.25rem;
                              color:var(--text-muted);font-size:.8rem;text-decoration:none">
                        <span>📊</span> Cloud Dashboard ↗
                    </a>
                    @if (!string.IsNullOrEmpty(activeTenantId))
                    {
                        <a href="@baseUrl/api/report?tenant=@activeTenantId"
                           target="_blank" rel="noopener"
                           title="Static snapshot report — no JS, printable"
                           style="display:flex;align-items:center;gap:.5rem;padding:.5rem 1.25rem;
                                  color:var(--text-muted);font-size:.8rem;text-decoration:none">
                            <span>📄</span> Snapshot Report ↗
                        </a>
                    }
                </li>
            }
        </ul>
    </nav>

    <main class="aarm-main">
        <ErrorBoundary>
            <ChildContent>@Body</ChildContent>
            <ErrorContent Context="ex">
                <div class="aarm-error">
                    <h3>Something went wrong</h3>
                    <pre>@ex.Message</pre>
                </div>
            </ErrorContent>
        </ErrorBoundary>
    </main>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // Wait for InitializeAsync() to complete (it runs fire-and-forget in App.xaml.cs).
        while (!InitSvc.IsInitialized)
            await Task.Delay(50);

        if (InitSvc.SetupRequired && !Nav.Uri.Contains("/startup"))
            Nav.NavigateTo("/startup", replace: true);
    }
}
