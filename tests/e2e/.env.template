# AARM E2E Test Configuration
# Kopiere diese Datei nach .env und trage die Werte ein.
# .env wird nie committed (steht in .gitignore).

# Azure Function URL (ohne trailing slash)
AARM_BASE_URL=https://aarm-dev-fn.azurewebsites.net

# Function Key (az functionapp keys list ... --query "functionKeys.default" -o tsv)
AARM_FUNCTION_KEY=

# Zieltenant — App Registration muss Application.Read.All haben
AARM_TEST_TENANT_ID=
AARM_TEST_TENANT_NAME=My Test Tenant

# App Registration im Zieltenant
AARM_TEST_CLIENT_ID=
AARM_TEST_CLIENT_SECRET=

# Environment-Name des Test-Jobs (wird nach dem Test wieder gelöscht)
AARM_TEST_ENV=E2E

# Wie lange auf Scan-Ergebnis warten (Sekunden, Standard: 60)
AARM_SCAN_TIMEOUT_SEC=60
