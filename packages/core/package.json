{
  "name": "@brunsforge/azure-app-registration-monitor",
  "version": "0.1.1",
  "description": "Monitor and analyse Microsoft Entra App Registration client secrets — read-only monitoring library for Node.js",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/brunsforge/AzureAppRegistrationSecretMonitor.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/brunsforge/AzureAppRegistrationSecretMonitor#readme",
  "bugs": {
    "url": "https://github.com/brunsforge/AzureAppRegistrationSecretMonitor/issues"
  },
  "keywords": [
    "microsoft-entra",
    "azure",
    "app-registration",
    "client-secret",
    "monitoring",
    "microsoft-graph",
    "entra-id",
    "secret-expiry",
    "preflight"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@azure/identity": "^4.4.0",
    "@azure/identity-cache-persistence": "^1.3.0",
    "@azure/monitor-query": "^1.3.0",
    "@microsoft/microsoft-graph-client": "^3.0.7"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
