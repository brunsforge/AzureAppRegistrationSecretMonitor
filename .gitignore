# ────────────────────────────────────────────────────────────────────────────
# Node.js / npm
# ────────────────────────────────────────────────────────────────────────────

node_modules/

# TypeScript build output — regenerated by `npm run build`
dist/
*.tsbuildinfo

# npm pack artefacts
*.tgz

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/

# ────────────────────────────────────────────────────────────────────────────
# .NET / MAUI
# ────────────────────────────────────────────────────────────────────────────

# Build outputs — regenerated by `dotnet build`
[Bb]in/
[Oo]bj/

# NuGet artefacts
*.nupkg
*.snupkg
nuget.config            # may contain private feed credentials

# Visual Studio local state (never commit these)
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.rsuser

# Rider local state
.idea/

# Test results
TestResults/
[Tt]est[Rr]esult*/
*.trx

# Publish profiles and launch settings that contain local paths
**/Properties/PublishProfiles/
**/Properties/launchSettings.json
*.pubxml.user

# Local development overrides (may contain local paths or debug settings)
appsettings.Development.json
appsettings.*.local.json

# Windows App SDK packaging
**/AppPackages/
**/BundleArtifacts/
Package.StoreAssociation.xml
_pkginfo.txt
*.appxupload
*.msixupload
*.msixbundle

# ────────────────────────────────────────────────────────────────────────────
# Secrets and credentials — NEVER commit these
# ────────────────────────────────────────────────────────────────────────────

.env
.env.*
*.env
!*.env.template
*.secret
*.secret.*

# Certificate private keys and bundles
*.pem
*.pfx
*.p12
*.key
*.jks

# Azure auth cache (created by az login or @azure/identity)
.azure/
msal_token_cache.json
msal_token_cache.json.bin

# @azure/identity-cache-persistence token cache files
msal.cache
*.msal.cache
*.msal.cache.bin

# aarm local config — lives in ~/.aarm, but guard against accidental copies
tenants.json
.aarm/

# ────────────────────────────────────────────────────────────────────────────
# Test coverage
# ────────────────────────────────────────────────────────────────────────────

coverage/
.nyc_output/

# ────────────────────────────────────────────────────────────────────────────
# Claude Code — local settings only; commands/skills/agents are committed
# ────────────────────────────────────────────────────────────────────────────

.claude/settings.local.json

# ────────────────────────────────────────────────────────────────────────────
# OS / editor artefacts
# ────────────────────────────────────────────────────────────────────────────

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
desktop.ini
$RECYCLE.BIN/
ehthumbs.db

# Vim / Emacs
*.swp
*.swo
*~
\#*\#

# JetBrains (covered above for Rider but also PyCharm, IDEA etc.)
*.iml

# ────────────────────────────────────────────────────────────────────────────
# Azure Function deployment staging directory — generated, never commit
apps/azure-function/_deploy/

# ────────────────────────────────────────────────────────────────────────────
# What IS committed (overrides above where needed)
# ────────────────────────────────────────────────────────────────────────────

# Lock file belongs in version control for reproducible installs
!package-lock.json

# Public certificate files are fine (no private key material)
!*.cer
!*.crt

# MAUI project files that look like .user but are project-level
!*.csproj
!*.sln
